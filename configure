#!/bin/sh
# yatl configure - a small handwritten configure script (no autoconf required).
# It probes the toolchain and writes a make include file (default: config.mk;
# overridable via the CONFIGFILE environment variable for cross-build wrappers).
#
# It performs no compile-and-RUN probes, so it works unchanged when cross-
# compiling, where target binaries cannot run on the build host. It only needs
# to pick shared-library conventions for the target OS.

set -e

# Options may be given directly (--prefix=DIR) or via the environment
# (PREFIX=DIR); an explicit option always overrides the environment.
prefix="${PREFIX:-/usr/local}"
enable_debug=0
enable_shared=1
# Target triple. Precedence: --host=TRIPLE > $HOST > $CONFIGURE_HOST > empty
# (empty means "target the build host", via uname).
host="${HOST:-${CONFIGURE_HOST:-}}"

for arg in "$@"; do
  case "$arg" in
    --prefix=*)       prefix="${arg#*=}" ;;
    --host=*)         host="${arg#*=}" ;;
    --enable-debug)   enable_debug=1 ;;
    --disable-shared) enable_shared=0 ;;
    --enable-shared)  enable_shared=1 ;;
    -h|--help)
      cat <<EOF
Usage: ./configure [OPTIONS]
  --prefix=DIR        installation root [\$PREFIX or /usr/local]
  --host=TRIPLE       target triple when cross-compiling [\$HOST or
                      \$CONFIGURE_HOST]
  --enable-debug      build with debug info and assertions
  --disable-shared    build the static library only
Environment: CC, AR, RANLIB, CFLAGS, LDFLAGS, CONFIGFILE are honoured.
  PREFIX provides the default for --prefix; HOST or CONFIGURE_HOST provides the
  default for --host; STATIC_BUILD=1 forces a static-only build.
EOF
      exit 0 ;;
    *) echo "configure: ignoring unknown option: $arg" >&2 ;;
  esac
done

CC="${CC:-cc}"
AR="${AR:-ar}"
RANLIB="${RANLIB:-ranlib}"
CONFIGFILE="${CONFIGFILE:-config.mk}"

# Determine the target OS for shared-library conventions. Prefer the explicit
# host triple (cross builds); otherwise fall back to the build host's uname.
case "$host" in
  *darwin*|*apple*)  target_os=darwin ;;
  *linux*)           target_os=linux ;;
  *mingw*|*windows*) target_os=windows ;;
  "")                target_os="$(uname -s 2>/dev/null || echo unknown)" ;;
  *)                 target_os=other ;;
esac
case "$target_os" in
  Darwin) target_os=darwin ;;
  Linux)  target_os=linux ;;
esac

# Library version: single source of truth is the public header.
version=$(sed -n 's/.*YATL_VERSION "\([^"]*\)".*/\1/p' include/yatl/yatl_version.h | head -1)
version="${version:-0.0.0}"
soversion="${version%%.*}"

EXE_EXT=""
case "$target_os" in
  darwin)
    SHLIB_EXT=dylib
    SHLIB_LDFLAGS="-dynamiclib -install_name $prefix/lib/libyatl.$soversion.dylib -compatibility_version $soversion -current_version $version" ;;
  windows)
    SHLIB_EXT=dll
    SHLIB_LDFLAGS="-shared"
    EXE_EXT=".exe" ;;
  *)
    SHLIB_EXT=so
    SHLIB_LDFLAGS="-shared -Wl,-soname,libyatl.so.$soversion" ;;
esac

# In cross/static environments shared libraries are usually undesirable.
if [ -n "${STATIC_BUILD}" ] && [ "${STATIC_BUILD}" != "0" ]; then
  enable_shared=0
fi

DEBUG_DEFAULT=0
[ "$enable_debug" = "1" ] && DEBUG_DEFAULT=1

cat > "$CONFIGFILE" <<EOF
# Generated by ./configure -- do not edit.
CC = $CC
AR = $AR
RANLIB = $RANLIB
PREFIX = $prefix
EXTRA_CFLAGS =
EXTRA_LDFLAGS =
SHLIB_EXT = $SHLIB_EXT
SHLIB_LDFLAGS = $SHLIB_LDFLAGS
EXE_EXT = $EXE_EXT
ENABLE_SHARED = $enable_shared
DEBUG_DEFAULT = $DEBUG_DEFAULT
EOF

# pkg-config file. Uses $version (read above) so it never drifts from
# YATL_VERSION / yatl_version() (single source of truth).
if [ -f yatl.pc.in ]; then
  sed -e "s#@PREFIX@#$prefix#g" -e "s#@VERSION@#$version#g" yatl.pc.in > yatl.pc
fi

echo "configure: writing $CONFIGFILE"
echo "  CC            = $CC"
echo "  prefix        = $prefix"
echo "  host triple   = ${host:-(build host)}"
echo "  target os     = $target_os"
echo "  exe suffix    = ${EXE_EXT:-(none)}"
echo "  shared lib    = $enable_shared ($SHLIB_EXT)"
echo "  version       = $version"
